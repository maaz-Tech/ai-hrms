# ── Core ────────────────────────────────────────────────────────────────
# SQLite by default (zero-config). For production use Postgres (Neon/Supabase):
#   DATABASE_URL=postgresql+psycopg://user:pass@host/dbname
DATABASE_URL=sqlite:///./hrms.db

# JWT signing secret — change in production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS: comma-separated allowed origins (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI (all optional — app degrades gracefully to heuristics if unset) ────
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Qdrant Cloud free tier (optional; falls back to in-memory). Leave blank for in-memory.
QDRANT_URL=
QDRANT_API_KEY=

# Embedding model (local sentence-transformers). Falls back to a hashing embedder if unavailable.
EMBEDDING_MODEL=all-MiniLM-L6-v2
